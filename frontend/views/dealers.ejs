<!DOCTYPE html>
<html lang="en">
<head>
 <%- include('partials/head') %>
</head>
<body>

<%- include('partials/navbar') %>

<div class="page-hero-premium">
  <div class="hero-ambient-bg"></div>
  <div class="hero-ambient-light"></div>
  <div class="hero-grain"></div>
  
  <!-- Particles pollen -->
  <div class="hero-particles">
    <div class="particle p-1"></div>
    <div class="particle p-2"></div>
    <div class="particle p-3"></div>
    <div class="particle p-4"></div>
    <div class="particle p-5"></div>
  </div>

  <div class="container relative z-10" style="position: relative; z-index: 10;">
    <div class="hero-glass-container">
      <div class="breadcrumb fade-up delay-1"><a href="/">Home</a> <span style="opacity:0.6; margin:0 6px;">/</span> Dealers</div>
      <h1 class="fade-up delay-2">Authorized Dealers</h1>
      <p class="fade-up delay-3">Find a Trishul Krushi Kendra dealer near your village across Pune, Nashik &amp; Ahmednagar.</p>
    </div>
  </div>
</div>

<section class="section">
 <div class="container">
 <!-- Stats strip -->
 <div class="dealer-stats-strip">
 <div class="dealer-stat"><span class="dstat-num" id="dstat-total"><%= stats.totalDealers %></span><span class="dstat-lbl">Dealers</span></div>
 <div class="dealer-stat"><span class="dstat-num"><%= stats.uniqueDistricts %></span><span class="dstat-lbl">Districts</span></div>
 <div class="dealer-stat"><span class="dstat-num">500+</span><span class="dstat-lbl">Farmers Served</span></div>
 <div class="dealer-stat"><span class="dstat-num">24/7</span><span class="dstat-lbl">Support</span></div>
 </div>

 <!-- Filter Bar -->
 <div class="filter-topbar" style="margin-bottom:1.5rem;">
 <div class="filter-pills">
 <a href="/dealers" class="filter-pill <%= district==='all' ? 'active':'' %>">All</a>
 <a href="/dealers?district=pune" class="filter-pill <%= district==='pune' ? 'active':'' %>"> Pune</a>
 <a href="/dealers?district=nashik" class="filter-pill <%= district==='nashik' ? 'active':'' %>"> Nashik</a>
 <a href="/dealers?district=ahmednagar" class="filter-pill <%= district==='ahmednagar' ? 'active':'' %>"> Ahmednagar</a>
 </div>
 <div class="result-count" id="api-result-count">Loading...</div>
 </div>

 <!-- Dealer Cards Container -->
 <div id="api-dealers-grid" class="dealer-grid" data-district="<%= district %>">
 <div style="text-align:center;padding:3rem 1rem;color:#6b7280;grid-column:1/-1;">
 <div style="font-size:2.5rem;margin-bottom:.75rem;">�</div>
 <p>Fetching authorized dealers...</p>
 </div>
 </div>
 </div>
</section>

<!-- Become a Dealer CTA -->
<section class="section bg-light">
 <div class="container" style="text-align:center;max-width:640px;">
 <div style="font-size:2.5rem;margin-bottom:1rem;">�</div>
 <h2>Want to Become a Dealer?</h2>
 <p style="margin:.75rem 0 1.5rem;color:var(--text-light);">Join our network of authorized dealers and grow your agricultural business with Trishul.</p>
 <a href="/become-dealer" class="btn btn-primary btn-lg">Apply Now →</a>
 </div>
</section>

<%- include('partials/footer') %>
<script src="/js/api.js"></script>
<script src="/js/dealer-api.js"></script>
<script src="/js/main.js"></script>
</body>
</html>

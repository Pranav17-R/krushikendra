<!DOCTYPE html>
<html lang="en">
<head>
 <%- include('partials/head') %>
</head>
<body>

<%- include('partials/navbar') %>

<div class="page-hero page-hero-green pattern-bg">
 <video autoplay muted loop playsinline style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;">
 <source src="/public/assets/assets/dealer.mp4" type="video/mp4">
 Your browser does not support the video tag.
 </video>
 
 <div class="container" style="position: relative; z-index: 1;">
 <div class="breadcrumb"><a href="/">Home</a> / Become a Dealer</div>
 <h1>Become an Authorised Dealer</h1>
 <p>Join our growing network of trusted agricultural dealers across Maharashtra and scale your business.</p>
 <a href="#apply-form" class="btn btn-primary hero-btn" style="margin-top: 1.5rem;">Apply Now ↓</a>
 </div>
</div>

<section class="section">
 <div class="container dealer-apply-layout">

 <!-- Perks Section -->
 <div class="dealer-perks">
   <h2 style="margin-bottom: 2rem; font-size: 2rem; color: var(--text-dark);">Why Partner with Trishul?</h2>
   <div class="perks-grid">
     <div class="perk-card">
       <div class="perk-icon-wrap">
         <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2-1 4-3 5.99-5.11a2 2 0 0 1 2.72-.08C15 2 17 4 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
       </div>
       <h3>Quality Products</h3>
       <p>Genuine, certified agricultural products from top manufacturers.</p>
     </div>
     <div class="perk-card">
       <div class="perk-icon-wrap">
         <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
       </div>
       <h3>Good Margins</h3>
       <p>Competitive dealer prices with seasonal incentives and rewards.</p>
     </div>
     <div class="perk-card">
       <div class="perk-icon-wrap">
         <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
       </div>
       <h3>Training Support</h3>
       <p>Product training, agronomy workshops, and marketing materials provided.</p>
     </div>
     <div class="perk-card">
       <div class="perk-icon-wrap">
         <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0v5a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3Z"/><path d="M21 16v2a4 4 0 0 1-4 4h-5"/></svg>
       </div>
       <h3>Dedicated Support</h3>
       <p>Your own Trishul relationship manager and priority customer service.</p>
     </div>
   </div>
 </div>

 <!-- Application Form -->
 <div class="form-card" id="apply-form">
 <% if (success) { %>
 <div class="success-box">
 <h2>Application Submitted!</h2>
 <p>Thank you! Our team will review your application and contact you within 2–3 business days.</p>
 <a href="/" class="btn btn-primary" style="margin-top:1.25rem;">← Back to Home</a>
 </div>
 <% } else { %>
 <div class="form-card-head">
 <span class="form-badge">DEALER APPLICATION</span>
 <h2>Apply Now</h2>
 <p>Fill in your details and we'll get back to you within 2–3 business days.</p>
 </div>
 <form method="POST" action="/become-dealer" class="enquiry-form" novalidate>
 <div class="form-row">
 <div class="form-group">
 <label for="dealerName">Your Name <span class="req">*</span></label>
 <input type="text" id="dealerName" name="dealerName" placeholder="Full Name"
 value="<%= formData.dealerName||'' %>"
 class="<%= errors.dealerName ? 'input-error':'' %>">
 <% if (errors.dealerName) { %><span class="field-error"><%= errors.dealerName %></span><% } %>
 </div>
 <div class="form-group">
 <label for="phone">Phone Number <span class="req">*</span></label>
 <input type="tel" id="phone" name="phone" placeholder="10-digit mobile" maxlength="10" inputmode="numeric"
 value="<%= formData.phone||'' %>"
 class="<%= errors.phone ? 'input-error':'' %>">
 <% if (errors.phone) { %><span class="field-error"><%= errors.phone %></span><% } %>
 </div>
 </div>
 <div class="form-group">
 <label for="shopName">Shop / Business Name <span class="req">*</span></label>
 <input type="text" id="shopName" name="shopName" placeholder="e.g. Vijay Agro Stores"
 value="<%= formData.shopName||'' %>"
 class="<%= errors.shopName ? 'input-error':'' %>">
 <% if (errors.shopName) { %><span class="field-error"><%= errors.shopName %></span><% } %>
 </div>
 <div class="form-row">
 <div class="form-group">
 <label for="village">Village / Town <span class="req">*</span></label>
 <input type="text" id="village" name="village" placeholder="Your village"
 value="<%= formData.village||'' %>"
 class="<%= errors.village ? 'input-error':'' %>">
 <% if (errors.village) { %><span class="field-error"><%= errors.village %></span><% } %>
 </div>
 <div class="form-group">
 <label for="district">District <span class="req">*</span></label>
 <select id="district" name="district" class="<%= errors.district ? 'input-error':'' %>">
 <option value="">Select district…</option>
 <% ['Pune','Nashik','Ahmednagar','Satara','Kolhapur','Solapur','Aurangabad','Other'].forEach(d => { %>
 <option value="<%= d %>" <%= formData.district===d ? 'selected':'' %>><%= d %></option>
 <% }) %>
 </select>
 <% if (errors.district) { %><span class="field-error"><%= errors.district %></span><% } %>
 </div>
 </div>
 <div class="form-group">
 <label for="experience">Agricultural Experience <span class="req">*</span></label>
 <select id="experience" name="experience" class="<%= errors.experience ? 'input-error':'' %>">
 <option value="">Select experience…</option>
 <option value="0-1" <%= formData.experience==='0-1' ? 'selected':'' %>>Less than 1 year</option>
 <option value="1-3" <%= formData.experience==='1-3' ? 'selected':'' %>>1–3 years</option>
 <option value="3-5" <%= formData.experience==='3-5' ? 'selected':'' %>>3–5 years</option>
 <option value="5+" <%= formData.experience==='5+' ? 'selected':'' %>>5+ years</option>
 </select>
 <% if (errors.experience) { %><span class="field-error"><%= errors.experience %></span><% } %>
 </div>
 <div class="form-group">
 <label for="message">Additional Message <span style="font-weight:400;color:var(--text-light);">(optional)</span></label>
 <textarea id="message" name="message" rows="3" placeholder="Tell us more about your business…"><%= formData.message||'' %></textarea>
 </div>
 <button type="submit" class="btn btn-primary btn-lg btn-full">Submit Application</button>
 </form>
 <% } %>
 </div>

 </div>
 </section>

 <section class="cta-banner">
   <div class="container" style="text-align: center;">
     <h2 style="margin-bottom: 1rem; color: var(--text-dark);">Start Your Dealer Journey Today</h2>
     <p style="margin-bottom: 2rem; color: var(--text-mid); font-size: 1.1rem;">Join thousands of successful partners growing with Trishul Krushi Kendra.</p>
     <a href="#apply-form" class="btn btn-primary btn-lg">Apply Now</a>
   </div>
 </section>

<%- include('partials/footer') %>
<script src="/js/api.js"></script>
<script src="/js/dealer-api.js"></script>
<script src="/js/main.js"></script>
</body>
</html>

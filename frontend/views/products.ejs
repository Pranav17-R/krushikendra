<!DOCTYPE html>
<html lang="en">
<head>
 <%- include('partials/head') %>
</head>
<body>

<%- include('partials/navbar') %>

<div class="page-hero-premium">
  <div class="hero-ambient-bg"></div>
  <div class="hero-ambient-light"></div>
  <div class="hero-grain"></div>
  
  <!-- Particles pollen -->
  <div class="hero-particles">
    <div class="particle p-1"></div>
    <div class="particle p-2"></div>
    <div class="particle p-3"></div>
    <div class="particle p-4"></div>
    <div class="particle p-5"></div>
  </div>

  <!-- Hero Video -->
  <video autoplay muted loop class="hero-video" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 5;">
    <source src="/assets/assets/video.mp4" type="video/mp4">
  </video>

  <div class="container relative z-10" style="position: relative; z-index: 10;">
    
      <div class="breadcrumb fade-up delay-1"><a href="/">Home</a> <span style="opacity:0.6; margin:0 6px;">/</span> Products</div>
      <h1 class="fade-up delay-2">Our Products</h1>
      <p class="fade-up delay-3">Quality fertilizers, pesticides &amp; crop-protection products — sourced from trusted manufacturers.</p>
   
  </div>
</div>

<section class="section">
 <div class="container">
 <!-- Filter Bar -->
 <div class="filter-topbar">
 <form class="filter-form" onsubmit="event.preventDefault();">
 <div class="search-wrap">
 <span class="search-icon"></span>
 <input type="text" data-api-search="true" placeholder="Search products…"
 value="<%= search %>" class="search-input">
 </div>
 <div class="filter-pills">
 <a href="#" data-api-filter="all" class="filter-pill <%= filter==='all' ? 'active':'' %>">All Products</a>
 <a href="#" data-api-filter="organic" class="filter-pill <%= filter==='organic' ? 'active':'' %>"> Organic</a>
 <a href="#" data-api-filter="chemical" class="filter-pill <%= filter==='chemical' ? 'active':'' %>"> Chemical</a>
 <a href="#" data-api-filter="pesticide" class="filter-pill <%= filter==='pesticide' ? 'active':'' %>"> Pesticides</a>
 <a href="#" data-api-filter="crop-protection" class="filter-pill <%= filter==='crop-protection' ? 'active':'' %>"> Crop Protection</a>
 </div>
 <div class="result-count" data-product-count>Fetching…</div>
 </form>
 </div>

 <!-- Product Grid -->
 <div id="api-products-grid" class="products-grid" data-filter="<%= filter %>" data-search="<%= search %>">
 <div style="text-align:center;padding:3rem 1rem;color:#6b7280;grid-column:1/-1;">
 <div style="font-size:2.5rem;margin-bottom:.75rem;"></div>
 <p>Loading products from database…</p>
 </div>
 </div>
 </div>
</section>

<%- include('partials/footer') %>
<script src="/js/api.js"></script>
<script src="/js/products-api.js"></script>
<script src="/js/main.js"></script>
</body>
</html>

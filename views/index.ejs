<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>

<%- include('partials/navbar') %>

<!-- Hero Section -->
<section id="home" class="hero">
  <div class="hero-scene">
    <div class="hero-sky"></div>
    <div class="hero-sun"></div>
    <div class="hero-hills">
      <div class="hill hill-1"></div>
      <div class="hill hill-2"></div>
      <div class="hill hill-3"></div>
    </div>
    <div class="field-rows" id="fieldRows"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-badge">🌿 Maharashtra's Trusted Agro Store</div>
    <h1 class="hero-title">Grow Smarter,<br><span class="hero-title-accent">Harvest More</span></h1>
    <p class="hero-sub">Quality fertilizers, pesticides &amp; expert advice — delivered to your doorstep. Trusted by <%= stats.farmers %>+ farmers across Pune, Nashik &amp; Ahmednagar.</p>
    <div class="hero-cta-group">
      <a href="/products" class="btn btn-primary btn-lg">🌱 Explore Products</a>
      <a href="/enquiry" class="btn btn-outline-light btn-lg">📞 Get Free Advice</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat"><span class="hero-stat-num"><%= stats.farmers %>+</span><span class="hero-stat-lbl">Happy Farmers</span></div>
      <div class="hero-stat-div"></div>
      <div class="hero-stat"><span class="hero-stat-num"><%= stats.years %>+</span><span class="hero-stat-lbl">Years Experience</span></div>
      <div class="hero-stat-div"></div>
      <div class="hero-stat"><span class="hero-stat-num"><%= stats.dealers %></span><span class="hero-stat-lbl">District Dealers</span></div>
      <div class="hero-stat-div"></div>
      <div class="hero-stat"><span class="hero-stat-num"><%= stats.products %>+</span><span class="hero-stat-lbl">Products</span></div>
    </div>
  </div>
</section>

<!-- Categories Section -->
<section class="section bg-light" id="categories">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">🌿 What We Offer</div>
      <h2 class="section-title">Our Product Categories</h2>
      <p class="section-sub">Everything your farm needs, sourced from trusted manufacturers.</p>
    </div>
    <div class="cat-grid">
      <a href="/products?filter=organic" class="cat-card">
        <div class="cat-icon-wrap" style="background:linear-gradient(135deg,#e8f5e9,#c8e6c9)">🌱</div>
        <h3>Organic Fertilizers</h3>
        <p>Bio-NPK, vermicompost, neem-based products for sustainable farming.</p>
        <span class="cat-link">Shop Now →</span>
      </a>
      <a href="/products?filter=chemical" class="cat-card">
        <div class="cat-icon-wrap" style="background:linear-gradient(135deg,#e3f2fd,#bbdefb)">🧪</div>
        <h3>Chemical Fertilizers</h3>
        <p>Urea, DAP, MOP and micronutrients for maximum crop yield.</p>
        <span class="cat-link">Shop Now →</span>
      </a>
      <a href="/products?filter=pesticide" class="cat-card">
        <div class="cat-icon-wrap" style="background:linear-gradient(135deg,#f3e5f5,#e1bee7)">🌿</div>
        <h3>Pesticides</h3>
        <p>Approved insecticides and fungicides to protect your crops.</p>
        <span class="cat-link">Shop Now →</span>
      </a>
      <a href="/products?filter=crop-protection" class="cat-card">
        <div class="cat-icon-wrap" style="background:linear-gradient(135deg,#fff8e1,#ffe082)">🛡️</div>
        <h3>Crop Protection</h3>
        <p>Growth regulators, weedicides, and harvest protection solutions.</p>
        <span class="cat-link">Shop Now →</span>
      </a>
    </div>
  </div>
</section>



<!-- Why Choose Us -->
<section class="section bg-light">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">💪 Why Trishul</div>
      <h2 class="section-title">Why Farmers Trust Us</h2>
    </div>
    <div class="why-scroll">
      <div class="why-card">
        <div class="why-card-num">01</div>
        <div class="why-icon-wrap" style="background:#e8f5e9">✅</div>
        <h4>Genuine Products</h4>
        <p>Every product is sourced directly from authorised companies — 100% authentic.</p>
      </div>
      <div class="why-card">
        <div class="why-card-num">02</div>
        <div class="why-icon-wrap" style="background:#e3f2fd">🧑‍🌾</div>
        <h4>Expert Agronomy Advice</h4>
        <p>Free consultation from experienced agronomists to help you choose the right product.</p>
      </div>
      <div class="why-card">
        <div class="why-card-num">03</div>
        <div class="why-icon-wrap" style="background:#fff8e1">📦</div>
        <h4>Dealer Network</h4>
        <p><%= stats.dealers %> local dealers — get products close to your farm.</p>
      </div>
      <div class="why-card">
        <div class="why-card-num">04</div>
        <div class="why-icon-wrap" style="background:#fce4ec">💰</div>
        <h4>Fair Pricing</h4>
        <p>Competitive prices with seasonal discounts and bulk order benefits.</p>
      </div>
    </div>
  </div>
</section>



<%- include('partials/footer') %>
<script src="/js/api.js"></script>
<script src="/js/products-api.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
